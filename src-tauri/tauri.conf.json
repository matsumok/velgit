{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "velgit",
  "version": "0.1.0",
  "identifier": "com.matsumok.velgit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "velgit",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "pdfium.dll": "pdfium.dll"
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
